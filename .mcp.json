{
  "mcpServers": {
    "metatrader": {
      "command": "python",
      "args": [
        "-m",
        "metatrader_mcp_server"
      ],
      "env": {
        "MT5_LOGIN": "<DEMO_LOGIN>",
        "MT5_PASSWORD": "<DEMO_PASSWORD>",
        "MT5_SERVER": "<DEMO_SERVER>"
      },
      "_note": "Use a DEMO account for all testing. Do NOT point tests at a live account."
    }
  }
}
